# ========================================================
# KATEGORI      : Konfigurasi Environment (Backend)
# DESKRIPSI     : Template variabel lingkungan untuk backend.
# PETUNJUK      : Salin file ini menjadi .env dan isi nilai yang sesuai.
# ========================================================

# --------------------------------------------------------
# KONFIGURASI DATABASE (MySQL)
# --------------------------------------------------------
DB_HOST=127.0.0.1                    # Alamat host database (localhost untuk development)
DB_PORT=3306                         # Port MySQL (default: 3306)
DB_NAME=project_portal               # Nama database yang digunakan
DB_USER=root                         # Username database
DB_PASSWORD=                         # Password database (kosongkan jika tidak ada)

# --------------------------------------------------------
# KONFIGURASI JWT (JSON Web Token)
# --------------------------------------------------------
JWT_SECRET=replace_with_a_strong_secret_minimum_32_chars  # Kunci rahasia untuk signing token (WAJIB diganti)
JWT_EXPIRES_IN=2h                    # Masa berlaku token (misal: 2h, 1d, 30m)

# --------------------------------------------------------
# KONFIGURASI APLIKASI
# --------------------------------------------------------
PORT=4000                            # Port yang digunakan oleh Express server
CORS_ORIGIN=http://localhost:5173    # Origin frontend yang diizinkan (pisahkan dengan koma jika lebih dari satu)
