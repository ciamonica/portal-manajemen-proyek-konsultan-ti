# ========================================================
# KATEGORI      : Konfigurasi Environment (Frontend)
# DESKRIPSI     : Template variabel lingkungan untuk frontend React (Vite).
# PETUNJUK      : Salin file ini menjadi .env dan sesuaikan jika diperlukan.
# ========================================================

# Base URL untuk panggilan API ke backend
# Default: /api (menggunakan proxy Vite di development, atau Nginx di production)
VITE_API_BASE=/api
